# ─── Proving Grounds — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# All variables are validated at boot via src/lib/env.ts (Zod).

# Database — Neon Postgres connection string
# Get from: https://console.neon.tech
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Upstash Redis — REST API for queue + rate limiting
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Vercel Blob — private evidence storage
# Get from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your-blob-token

# Better Auth — admin authentication secret (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-32-plus-char-secret-here

# Vercel AI SDK — LLM-as-judge gateway key
# Get from: https://vercel.com/ai
AI_GATEWAY_API_KEY=your-ai-gateway-key

# App URL (public)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node env
NODE_ENV=development
