{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "version",
    "claims"
  ],
  "properties": {
    "version": {
      "const": "0.1"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "statement",
          "probe"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "type": {
            "enum": [
              "intended_delta",
              "invariant"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "probe": {
            "type": "object",
            "required": [
              "command"
            ],
            "properties": {
              "command": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 100,
                "maximum": 600000
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
